# =============================================
#  Editorial Blogger — Environment Variables
# =============================================

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# --- OCR.space (Image Text Extraction) ---
# Get your free key at: https://ocr.space/OCRAPI
OCR_SPACE_API_KEY=helloworld

# --- RenderForm (Thumbnail Generator) ---
RENDERFORM_API_KEY=
RENDERFORM_TEMPLATE=

# --- Google Blogger ---
BLOGGER_BLOG_ID=
# OAuth2 credentials (from Google Cloud Console)
BLOGGER_CLIENT_ID=your_blogger_client_id
BLOGGER_CLIENT_SECRET=your_blogger_client_secret
BLOGGER_REFRESH_TOKEN=your_blogger_refresh_token

# --- Google Drive (Thumbnail Upload) ---
GOOGLE_DRIVE_FOLDER_ID=
# OAuth2 credentials shared with Blogger or separate
GOOGLE_DRIVE_CLIENT_ID=your_drive_client_id
GOOGLE_DRIVE_CLIENT_SECRET=your_drive_client_secret
GOOGLE_DRIVE_REFRESH_TOKEN=your_drive_refresh_token

# --- Google Indexing API (Service Account) ---
# Path to your service account JSON key file
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# --- Sitemap Ping ---
SITEMAP_URL=
# --- Server ---
PORT=3000
